{
    "BriefEncounter": {
        "desc": "突发活动",
        "max_hit": 1,
        "next": [
            "OutpostEnterBriefEncounter",
            "CommonEndTask"
        ]
    },
    "OutpostEnterBriefEncounter": {
        "desc": "进入突发活动",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "OutpostDailyLivesAvailable",
                    "OutpostStaminaAvailable"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500,
        "next": [
            "OutpostDailyLives",
            "OutpostEnterBriefEncounter",
            "CommonEndTask"
        ]
    },
    "OutpostDailyLivesAvailable": {
        "desc": "日常状态次数足够",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    62,
                    57,
                    40,
                    24
                ],
                "expected": [
                    "^[1-9]\\d*$"
                ]
            }
        }
    },
    "OutpostStaminaAvailable": {
        "desc": "体力次数足够",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    128,
                    62,
                    21,
                    14
                ],
                "expected": [
                    "^[1-9]\\d*$"
                ]
            }
        }
    },
    "OutpostDailyLives": {
        "desc": "日常状态",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    3,
                    86,
                    183,
                    52
                ],
                "template": [
                    "Outpost/DailyLives.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500,
        "next": [
            "OutpostEnterDailyEvent"
        ]
    },
    "OutpostEnterDailyEvent": {
        "desc": "进入活动",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    756,
                    566,
                    41,
                    38
                ],
                "template": [
                    "Outpost/Event.png"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 500,
        "next": [
            "OutpostDailyEventFlow"
        ]
    },
    "OutpostDailyEventFlow": {
        "desc": "进入剧情",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    713,
                    437,
                    44,
                    27
                ],
                "expected": [
                    "确认"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_delay": 2500,
        "next": [
            "[JumpBack]CommonConfirmAction",
            "[JumpBack]DialoguesSkipStory",
            "[JumpBack]CommonConfirmReward",
            "[JumpBack]ExitDailyEventPage",
            "BriefEncounterRepeat",
            "OutpostDailyEventFlow"
        ]
    },
    "ExitDailyEventPage": {
        "desc": "退出活动页面",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    571,
                    660,
                    67,
                    49
                ],
                "template": [
                    "Common/CloseButton5.png"
                ],
                "green_mask": true
            }
        },
        "action": {
            "type": "Click"
        }
    },
    "BriefEncounterRepeat": {
        "desc": "再次执行突发活动",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "OutpostMainPageEntered"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "post_wait_freezes": 500,
        "next": [
            "OutpostEnterBriefEncounter",
            "CommonEndTask"
        ]
    }
}
